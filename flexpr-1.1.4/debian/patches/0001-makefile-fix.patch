Description: Fix upstream makefile installation paths and flags
Author: mikachelya <mikachelya@gmail.com>
Forwarded: not-needed
Index: flexpr-1.1.4/makefile
===================================================================
--- flexpr-1.1.4.orig/makefile
+++ flexpr-1.1.4/makefile
@@ -1,22 +1,45 @@
-flags ?= -Wall -Wextra -g
+CC      ?= gcc
+CFLAGS  ?= -Wall -g
+LDFLAGS ?=
+LDLIBS  := -lm
 
-flexpr: flexpr.c flexpr.h help.h object/tokenizer.o object/shuntingyard.o object/evaluator.o makefile
-	gcc $(flags) -o flexpr flexpr.c object/*.o -lm
+OBJDIR  := object
+OBJS    := $(OBJDIR)/tokenizer.o $(OBJDIR)/shuntingyard.o $(OBJDIR)/evaluator.o
+prefix = /usr
+BINDIR  := $(DESTDIR)$(prefix)/bin
+MANDIR  := $(DESTDIR)$(prefix)/share/man/man1
 
-object/tokenizer.o: tokenizer.c makefile | object
-	gcc $(flags) -c -o object/tokenizer.o tokenizer.c
+.PHONY: all clean install uninstall
 
-object/shuntingyard.o: shuntingyard.c makefile | object
-	gcc $(flags) -c -o object/shuntingyard.o shuntingyard.c
+all: flexpr
 
-object/evaluator.o: evaluator.c makefile | object
-	gcc $(flags) -c -o object/evaluator.o evaluator.c
+flexpr: flexpr.c flexpr.h help.h $(OBJS) | $(OBJDIR)
+	$(CC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) -o $@ flexpr.c $(OBJS) $(LDLIBS)
 
-object:
-	mkdir -p object
+$(OBJDIR)/%.o: %.c makefile | $(OBJDIR)
+	$(CC) $(CFLAGS) $(CPPFLAGS) -c -o $@ $<
 
-test: flexpr
-	./tests/tests.sh
+$(OBJDIR):
+	mkdir -p $(OBJDIR)
 
-release:
-	flags=-o3 make
\ No newline at end of file
+clean:
+	rm -rf $(OBJDIR) flexpr
+
+install: flexpr
+	# Ensure the target directories exist in the build staging area
+	install -d $(BINDIR)
+	install -d $(MANDIR)
+
+	# Install the binary with proper executable permissions (rwxr-xr-x)
+	install -m 755 flexpr $(BINDIR)/flexpr
+
+	# Install the manual page with read-only permissions (rw-r--r--)
+	# (Uncomment this once your pandoc/ronn manpage is ready)
+	# install -m 644 flexpr.1 $(MANDIR)/flexpr.1
+
+uninstall:
+	rm -f $(BINDIR)/flexpr
+	rm -f $(MANDIR)/flexpr.1
+
+zip-%:
+	tar -cvzf ../flexpr-$*.tar.gz *.c *.h LICENSE.md makefile
\ No newline at end of file
